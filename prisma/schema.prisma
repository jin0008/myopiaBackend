generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model country {
  id                      String                    @id(map: "country_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @unique(map: "country_unique")
  code                    String                    @unique(map: "country_unique_1") @db.VarChar(2)
  healthcare_professional healthcare_professional[]
  hospital                hospital[]
}

model ethnicity {
  id                      String                    @id(map: "ethnicity_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @unique(map: "ethnicity_unique") @db.VarChar(25)
  healthcare_professional healthcare_professional[]
  patient                 patient[]
}

model healthcare_professional {
  name                     String
  country_id               String                     @db.Uuid
  approved                 Boolean                    @default(false)
  hospital_id              String                     @db.Uuid
  user_id                  String                     @id(map: "healthcare_professional_pk") @db.Uuid
  default_ethnicity_id     String?                    @db.Uuid
  default_instrument_id    String?                    @db.Uuid
  is_admin                 Boolean                    @default(false)
  role                     String                     @db.VarChar
  country                  country                    @relation(fields: [country_id], references: [id], onDelete: Cascade, map: "healthcare_professional_country_fk")
  default_ethnicity        ethnicity?                 @relation(fields: [default_ethnicity_id], references: [id], onDelete: Cascade, map: "healthcare_professional_ethnicity_fk")
  hospital                 hospital                   @relation(fields: [hospital_id], references: [id], onDelete: Cascade, map: "healthcare_professional_hospital_fk")
  default_instrument       instrument?                @relation(fields: [default_instrument_id], references: [id], onDelete: Cascade, map: "healthcare_professional_instrument_fk")
  user                     user                       @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "healthcare_professional_user_fk")
  pending_patient_deletion pending_patient_deletion[]
}

model hospital {
  id                      String                    @id(map: "hospital_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @unique(map: "hospital_unique")
  country_id              String                    @db.Uuid
  code                    String                    @unique(map: "hospital_unique_1") @db.VarChar
  healthcare_professional healthcare_professional[]
  country                 country                   @relation(fields: [country_id], references: [id], map: "hospital_country_fk")
  patient                 patient[]
  child_hospital_link     child_hospital_link[]
  alert_recipient         alert_recipient[]
  study_hospital          study_hospital[]
}

/// Email addresses designated by a hospital admin to receive query (abnormal
/// measurement) alerts for that hospital.
model alert_recipient {
  id          String   @id(map: "alert_recipient_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospital_id String   @db.Uuid
  email       String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  hospital    hospital @relation(fields: [hospital_id], references: [id], onDelete: Cascade, map: "alert_recipient_hospital_fk")

  @@unique([hospital_id, email], map: "alert_recipient_hospital_email_unique")
}

model instrument {
  id                      String                    @id(map: "instrument_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @unique(map: "instrument_unique") @db.VarChar(20)
  healthcare_professional healthcare_professional[]
  measurement             measurement[]
}

model measurement {
  id            String     @id(map: "measurement_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id    String     @db.Uuid
  date          DateTime   @db.Date
  instrument_id String     @db.Uuid
  creator_id    String?    @db.Uuid
  od            Float?     @db.Real
  os            Float?     @db.Real
  instrument    instrument @relation(fields: [instrument_id], references: [id], onDelete: NoAction, map: "measurement_instrument_fk")
  patient       patient    @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "measurement_patient_fk")
  user          user?      @relation(fields: [creator_id], references: [id], map: "measurement_user_fk")
  study_visit   study_visit[]
}

model normal_user {
  user_id String @id(map: "normal_user_pk") @db.Uuid
  user    user   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "normal_user_user_fk")
}

model password_auth {
  user_id  String @id(map: "password_auth_pk") @db.Uuid
  username String @unique(map: "password_auth_unique") @db.VarChar
  hash     String @db.VarChar
  user     user   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "password_auth_user_fk")
}

model patient {
  id                             String                           @id(map: "patient_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospital_id                    String                           @db.Uuid
  sex                            sex
  ethnicity_id                   String                           @db.Uuid
  creator_id                     String?                          @db.Uuid
  email                          String?
  created_at                     DateTime                         @default(now()) @db.Timestamp(6)
  encrypted_registration_number  Bytes
  registration_number_hash       String
  encrypted_date_of_birth        Bytes
  measurement                    measurement[]
  ethnicity                      ethnicity                        @relation(fields: [ethnicity_id], references: [id], map: "patient_ethnicity_fk")
  hospital                       hospital                         @relation(fields: [hospital_id], references: [id], onDelete: Cascade, map: "patient_hospital_fk")
  creator                        user?                            @relation(fields: [creator_id], references: [id], map: "patient_user_fk")
  patient_k                      patient_k[]
  study_enrollment               study_enrollment[]
  patient_nearwork_activity      patient_nearwork_activity[]
  patient_outdoor_activity       patient_outdoor_activity[]
  patient_parental_myopia_status patient_parental_myopia_status[]
  patient_treatment              patient_treatment[]
  pending_patient_deletion       pending_patient_deletion?
  refractive_error               refractive_error[]
  user_patient                   user_patient[]
  child_hospital_link            child_hospital_link[]
  patient_consent                patient_consent[]

  @@unique([registration_number_hash, hospital_id], map: "patient_registration_number_hash_unique")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model patient_treatment {
  id           String    @id(map: "patients_treatments_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id   String    @db.Uuid
  treatment_id String    @db.Uuid
  start_date   DateTime  @db.Date
  end_date     DateTime? @db.Date
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  patient      patient   @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "patient_treatment_patient_fk")
  treatment    treatment @relation(fields: [treatment_id], references: [id], onDelete: Cascade, map: "patient_treatment_treatment_fk")
}

model session {
  id          String   @id(map: "session_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_key String   @unique(map: "session_unique")
  user_id     String   @db.Uuid
  valid_until DateTime @db.Timestamp(6)
  user        user     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "session_user_fk")
}

model treatment {
  id                String              @id(map: "treatment_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String              @unique(map: "treatment_unique") @db.VarChar(30)
  description       String?
  patient_treatment patient_treatment[]
}

model user {
  id                      String                   @id(map: "user_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at              DateTime                 @default(now()) @db.Timestamp(6)
  is_site_admin           Boolean                  @default(false)
  email                   String?
  receive_email_updates   Boolean                  @default(false)
  google_auth             google_auth?
  healthcare_professional healthcare_professional?
  measurement             measurement[]
  normal_user             normal_user?
  password_auth           password_auth?
  patient                 patient[]
  refractive_error        refractive_error[]
  session                 session[]
  user_patient            user_patient[]
  audit_log               audit_log[]
  parent_child_link       parent_child_link[]
  mobile_refresh_token    mobile_refresh_token[]
  oauth_identity          oauth_identity[]
  community_post          community_post[]
  community_comment       community_comment[]
  community_post_like     community_post_like[]
  community_comment_like  community_comment_like[]
  user_consent            user_consent[]
  patient_consent         patient_consent[]
  study_enrollment        study_enrollment[]
  study_visit             study_visit[]
}

model user_patient {
  user_id    String  @db.Uuid
  patient_id String  @db.Uuid
  patient    patient @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "user_patient_patient_fk")
  user       user    @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "user_patient_user_fk")

  @@unique([user_id, patient_id], map: "user_patient_unique")
}

model growth_data {
  age        Int
  percentile Int
  value      Float  @db.Real
  sex        sex
  ethnicity  String @db.VarChar

  @@unique([age, percentile, sex, ethnicity], map: "growth_data_unique")
}

/// Age/sex-specific axial length warning threshold (mm). A measurement whose
/// od/os exceeds `warn_max` for the patient's age triggers an alert. Seeded with
/// placeholder values; the clinical table is supplied by the client.
model axial_length_threshold {
  age      Int
  sex      sex
  warn_max Float @db.Real

  @@unique([age, sex], map: "axial_length_threshold_unique")
}

model google_auth {
  user_id         String @id(map: "google_auth_pk") @db.Uuid
  google_identity String @unique(map: "google_auth_unique")
  user            user   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "google_auth_user_fk")
}

model patient_k {
  patient_id String  @db.Uuid
  k_type     ktype
  od         Float?  @db.Real
  os         Float?  @db.Real
  patient    patient @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "patient_k_patient_fk")

  @@unique([patient_id, k_type], map: "patient_k_unique")
}

model pending_patient_deletion {
  patient_id              String                  @id(map: "pending_patient_deletion_pk") @db.Uuid
  requested_by            String                  @db.Uuid
  request_date            DateTime                @default(now()) @db.Timestamp(6)
  healthcare_professional healthcare_professional @relation(fields: [requested_by], references: [user_id], onDelete: Cascade, map: "pending_patient_deletion_healthcare_professional_fk")
  patient                 patient                 @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "pending_patient_deletion_patient_fk")
}

model patient_nearwork_activity {
  id         String   @id(map: "patient_nearwork_activity_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id String   @db.Uuid
  timestamp  DateTime @default(now()) @db.Timestamp(6)
  hours      Int?
  patient    patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "patient_nearwork_activity_patient_fk")
}

model patient_outdoor_activity {
  id         String   @id(map: "patient_outdoor_activity_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id String   @db.Uuid
  timestamp  DateTime @default(now()) @db.Timestamp(6)
  hours      Int?
  patient    patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "patient_outdoor_activity_patient_fk")
}

model patient_parental_myopia_status {
  id         String        @id(map: "patient_parental_myopia_status_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_sex sex
  patient_id String        @db.Uuid
  status     myopia_status
  timestamp  DateTime      @default(now()) @db.Timestamp(6)
  patient    patient       @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "patient_parental_myopia_status_patient_fk")
}

model refractive_error {
  id                      String                  @id(map: "refractive_error_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  method_id               Int
  od_sph                  Float?                  @db.Real
  od_cyl                  Float?                  @db.Real
  os_cyl                  Float?                  @db.Real
  os_sph                  Float?                  @db.Real
  date                    DateTime                @db.Date
  creator_id              String?                 @db.Uuid
  patient_id              String                  @db.Uuid
  patient                 patient                 @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "refractive_error_patient_fk")
  refractive_error_method refractive_error_method @relation(fields: [method_id], references: [id], onDelete: NoAction, map: "refractive_error_refactive_error_method_fk")
  user                    user?                   @relation(fields: [creator_id], references: [id], map: "refractive_error_user_fk")
}

model refractive_error_method {
  id               Int                @id(map: "refractive_error_method_pk") @default(autoincrement())
  name             String             @unique(map: "refractive_error_method_unique")
  refractive_error refractive_error[]
}

model audit_log {
  id                String       @id(map: "audit_log_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  table_name        String
  record_id         String?      @db.Uuid
  action            audit_action
  status            audit_status @default(SUCCESS)
  actor_id          String?      @db.Uuid
  actor_name        String?
  actor_role        String?
  actor_hospital_id String?      @db.Uuid
  patient_id        String?      @db.Uuid
  hospital_id       String?      @db.Uuid
  ip_address        String?
  user_agent        String?
  changed_fields    String[]     @default([])
  old_value         Json?
  new_value         Json?
  error_message     String?
  created_at        DateTime     @default(now()) @db.Timestamptz(6)
  actor             user?        @relation(fields: [actor_id], references: [id], map: "audit_log_user_fk")

  @@index([patient_id, created_at(sort: Desc)], map: "audit_log_patient_created_idx")
  @@index([actor_id, created_at(sort: Desc)], map: "audit_log_actor_created_idx")
  @@index([hospital_id, created_at(sort: Desc)], map: "audit_log_hospital_created_idx")
  @@index([created_at(sort: Desc)], map: "audit_log_created_idx")
}

enum audit_action {
  CREATE
  UPDATE
  DELETE
  READ
  EXPORT
}

enum audit_status {
  SUCCESS
  FAILURE
  REVERTED
}

/// Account-level consent captured at signup (이용약관 / 개인정보 수집·이용 / 마케팅).
/// One row per consent item per user. `version` records WHICH version of the
/// document the user agreed to, so re-consent after a policy revision is auditable.
/// This is required to demonstrate valid consent under the Korean PIPA (개인정보보호법).
model user_consent {
  id           String       @id(map: "user_consent_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String       @db.Uuid
  consent_type consent_type
  version      String
  agreed       Boolean
  agreed_at    DateTime     @default(now()) @db.Timestamptz(6)
  user         user         @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "user_consent_user_fk")

  @@index([user_id], map: "idx_user_consent_user")
}

/// Patient-level consent for SENSITIVE data (민감정보: 등록번호·생년월일·안축장 등).
/// The data subject is the patient (child). This row records the legal basis by
/// which their sensitive data is processed — currently only `legal_guardian`:
/// a parent (법정대리인) consents at the moment they link the child to a hospital
/// record, since that is when the hospital-registered sensitive data becomes
/// visible to them. `given_by` is the user (parent) who gave the consent.
model patient_consent {
  id         String               @id(map: "patient_consent_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id String               @db.Uuid
  given_by   String               @db.Uuid
  role       patient_consent_role
  version    String
  agreed_at  DateTime             @default(now()) @db.Timestamptz(6)
  patient    patient              @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "patient_consent_patient_fk")
  user       user                 @relation(fields: [given_by], references: [id], onDelete: Cascade, map: "patient_consent_user_fk")

  @@index([patient_id], map: "idx_patient_consent_patient")
  @@index([given_by], map: "idx_patient_consent_given_by")
}

enum consent_type {
  terms_of_service
  privacy_policy
  marketing
}

enum patient_consent_role {
  legal_guardian
  hospital_attestation
}

enum sex {
  male
  female
}

enum ktype {
  K1
  K2
}

enum myopia_status {
  myopia
  high_myopia
  emmetropia
  hyperopia
  unknown
}

/// Parent (app user) ↔ child profile. One user may have many children.
/// Contains the child's display nickname and identity fields the app collected
/// locally — these are used to match against a hospital patient record when
/// the parent attempts to link a hospital.
model parent_child_link {
  id                  String                @id(map: "parent_child_link_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String                @db.Uuid
  nickname            String
  date_of_birth       DateTime              @db.Date
  sex                 sex
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  user                user                  @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "parent_child_link_user_fk")
  child_hospital_link child_hospital_link[]

  @@index([user_id], map: "idx_parent_child_link_user")
}

/// Link between a parent's child profile and an actual hospital patient record.
/// When a parent deletes a child profile, these links cascade-delete BUT the
/// underlying patient record and its measurements stay intact at the hospital.
model child_hospital_link {
  id                   String            @id(map: "child_hospital_link_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_child_link_id String            @db.Uuid
  hospital_id          String            @db.Uuid
  patient_id           String            @db.Uuid
  status               String            @default("active")
  linked_at            DateTime          @default(now()) @db.Timestamptz(6)
  parent_child_link    parent_child_link @relation(fields: [parent_child_link_id], references: [id], onDelete: Cascade, map: "child_hospital_link_parent_child_link_fk")
  hospital             hospital          @relation(fields: [hospital_id], references: [id], map: "child_hospital_link_hospital_fk")
  patient              patient           @relation(fields: [patient_id], references: [id], map: "child_hospital_link_patient_fk")

  @@unique([parent_child_link_id, hospital_id], map: "child_hospital_link_unique")
}

/// Refresh tokens for the mobile app. Access tokens are stateless JWTs.
model mobile_refresh_token {
  id           String                 @id(map: "mobile_refresh_token_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String                 @db.Uuid
  token_hash   String                 @unique(map: "mobile_refresh_token_hash_unique")
  expires_at   DateTime               @db.Timestamptz(6)
  created_at   DateTime               @default(now()) @db.Timestamptz(6)
  rotated_from String?                @db.Uuid
  revoked_at   DateTime?              @db.Timestamptz(6)
  user         user                   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "mobile_refresh_token_user_fk")
  parent       mobile_refresh_token?  @relation("mobile_refresh_token_rotation", fields: [rotated_from], references: [id], map: "mobile_refresh_token_rotated_from_fk")
  rotations    mobile_refresh_token[] @relation("mobile_refresh_token_rotation")

  @@index([user_id], map: "idx_refresh_user")
}

/// OAuth identities per social provider (Apple / Google / Kakao / Naver).
/// The existing google_auth table is kept for the web flow; this new table
/// is specifically for the mobile app's multi-provider flow.
model oauth_identity {
  id         String   @id(map: "oauth_identity_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  provider   String
  subject    String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "oauth_identity_user_fk")

  @@unique([provider, subject], map: "oauth_identity_provider_subject_unique")
}

/// Community board (자유게시판) — added for the EAGLE vision iOS app so
/// signed-in regular users can post threads, comment, reply, and like.
/// Posts and comments are soft-deleted (deleted_at) so reply chains
/// stay intact and moderation actions are reversible.
model community_post {
  id         String                @id(map: "community_post_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String                @db.Uuid
  title      String
  body       String
  created_at DateTime              @default(now()) @db.Timestamptz(6)
  updated_at DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at DateTime?             @db.Timestamptz(6)
  user       user                  @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "community_post_user_fk")
  comments   community_comment[]
  likes      community_post_like[]

  @@index([created_at(sort: Desc)], map: "idx_community_post_created_at")
  @@index([user_id], map: "idx_community_post_user")
}

/// One row per comment OR reply. A reply is just a comment with
/// `parent_comment_id` pointing at another comment in the same post.
/// Replies-of-replies are flattened to a single level in the UI by
/// treating any parent_comment_id as a top-level "this is a reply".
model community_comment {
  id                String                   @id(map: "community_comment_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id           String                   @db.Uuid
  user_id           String                   @db.Uuid
  parent_comment_id String?                  @db.Uuid
  body              String
  created_at        DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at        DateTime                 @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at        DateTime?                @db.Timestamptz(6)
  user              user                     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "community_comment_user_fk")
  post              community_post           @relation(fields: [post_id], references: [id], onDelete: Cascade, map: "community_comment_post_fk")
  parent            community_comment?       @relation("comment_replies", fields: [parent_comment_id], references: [id], onDelete: Cascade, map: "community_comment_parent_fk")
  replies           community_comment[]      @relation("comment_replies")
  likes             community_comment_like[]

  @@index([post_id, created_at], map: "idx_community_comment_post")
  @@index([parent_comment_id], map: "idx_community_comment_parent")
  @@index([user_id], map: "idx_community_comment_user")
}

/// Idempotent "liked" record. The (user_id, post_id) composite key
/// makes liking twice a no-op at the DB level — the API converts that
/// into a 200 OK with the same response shape as the first like.
model community_post_like {
  user_id    String         @db.Uuid
  post_id    String         @db.Uuid
  created_at DateTime       @default(now()) @db.Timestamptz(6)
  user       user           @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "community_post_like_user_fk")
  post       community_post @relation(fields: [post_id], references: [id], onDelete: Cascade, map: "community_post_like_post_fk")

  @@id([user_id, post_id], map: "community_post_like_pk")
  @@index([post_id], map: "idx_community_post_like_post")
}

model community_comment_like {
  user_id    String            @db.Uuid
  comment_id String            @db.Uuid
  created_at DateTime          @default(now()) @db.Timestamptz(6)
  user       user              @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "community_comment_like_user_fk")
  comment    community_comment @relation(fields: [comment_id], references: [id], onDelete: Cascade, map: "community_comment_like_comment_fk")

  @@id([user_id, comment_id], map: "community_comment_like_pk")
  @@index([comment_id], map: "idx_community_comment_like_comment")
}

/// A clinical study (임상연구) patients can be enrolled into, e.g.
/// "LPTAT-OS: 마이오클리어 0.05% PMS". Master list managed by site admins.
model study {
  id               String             @id(map: "study_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @unique(map: "study_unique")
  code             String?            @db.VarChar
  description      String?
  active           Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  study_hospital   study_hospital[]
  study_enrollment study_enrollment[]
}

/// Which hospitals may participate in a given study (admin-designated). A
/// hospital sees the 연구 button only if it has at least one row here.
model study_hospital {
  study_id    String   @db.Uuid
  hospital_id String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  study       study    @relation(fields: [study_id], references: [id], onDelete: Cascade, map: "study_hospital_study_fk")
  hospital    hospital @relation(fields: [hospital_id], references: [id], onDelete: Cascade, map: "study_hospital_hospital_fk")

  @@id([study_id, hospital_id], map: "study_hospital_pk")
  @@index([hospital_id], map: "idx_study_hospital_hospital")
}

/// A patient enrolled into a study (연구환자 등록). One row per (study, patient).
model study_enrollment {
  id          String        @id(map: "study_enrollment_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  study_id    String        @db.Uuid
  patient_id  String        @db.Uuid
  enrolled_by String?       @db.Uuid
  enrolled_at DateTime      @default(now()) @db.Timestamptz(6)
  status      String        @default("active")
  /// De-identified subject number shown in alert emails instead of any patient
  /// identifier. Format: {studyCode}-{hospitalCode}-{seq}, e.g. LPTAT-OS-001,
  /// numbered per (study, hospital). Assigned automatically at enrollment.
  subject_number String?    @db.VarChar
  study       study         @relation(fields: [study_id], references: [id], onDelete: Cascade, map: "study_enrollment_study_fk")
  patient     patient       @relation(fields: [patient_id], references: [id], onDelete: Cascade, map: "study_enrollment_patient_fk")
  enroller    user?         @relation(fields: [enrolled_by], references: [id], map: "study_enrollment_user_fk")
  study_visit study_visit[]

  @@unique([study_id, patient_id], map: "study_enrollment_unique")
  @@unique([study_id, subject_number], map: "study_enrollment_subject_unique")
  @@index([patient_id], map: "idx_study_enrollment_patient")
}

/// One study-visit data-entry record (방문 1건). Un-entered numeric/text fields
/// stay NULL and render as "N.D." in the UI. Axial length is NOT stored here —
/// it is written back to the shared `measurement` table and referenced via
/// measurement_id so it also appears on the main growth chart.
model study_visit {
  id            String   @id(map: "study_visit_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollment_id String   @db.Uuid
  visit_date    DateTime @db.Date
  created_by    String?  @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  // 1) Snellen visual acuity (0.0–1.5)
  va_od Float? @db.Real
  va_os Float? @db.Real

  // 2) Best corrected visual acuity (0.0–1.5)
  bcva_od Float? @db.Real
  bcva_os Float? @db.Real

  // 3) Refraction (Auto/MR/CR) — snapshot, includes axis
  refraction_method refraction_method?
  ref_od_sph        Float?             @db.Real
  ref_od_cyl        Float?             @db.Real
  ref_od_axis       Int?
  ref_os_sph        Float?             @db.Real
  ref_os_cyl        Float?             @db.Real
  ref_os_axis       Int?

  // 4) Slit lamp (전안부) — normal/abnormal + free-text finding per eye
  slitlamp_od_normal  Boolean?
  slitlamp_od_finding String?
  slitlamp_os_normal  Boolean?
  slitlamp_os_finding String?

  // 5) Intraocular pressure (mmHg, 0.0–50.0)
  iop_od Float? @db.Real
  iop_os Float? @db.Real

  // 6) Accommodation (Diopters, 0.0–20.0)
  accom_od Float? @db.Real
  accom_os Float? @db.Real

  // 7) Axial length — linked to the shared measurement row (write-back)
  measurement_id String? @db.Uuid

  // 8) Concomitant medication (free text)
  concomitant_meds String?

  // 9) Adverse event report (free text)
  adverse_event String?

  enrollment  study_enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade, map: "study_visit_enrollment_fk")
  creator     user?            @relation(fields: [created_by], references: [id], map: "study_visit_user_fk")
  measurement measurement?     @relation(fields: [measurement_id], references: [id], onDelete: SetNull, map: "study_visit_measurement_fk")

  @@index([enrollment_id, visit_date(sort: Desc)], map: "idx_study_visit_enrollment")
}

enum refraction_method {
  Auto
  MR
  CR
}
